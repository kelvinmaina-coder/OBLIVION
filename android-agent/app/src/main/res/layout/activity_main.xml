<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_background"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🦅 OBLIVION"
        android:textColor="@color/cyber_green"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginTop="30dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Security Testing Framework"
        android:textColor="@color/cyber_blue"
        android:textSize="14sp"
        android:layout_gravity="center"
        android:layout_marginBottom="30dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#1A1A2E"
        android:padding="15dp"
        android:layout_marginBottom="20dp">

        <View
            android:id="@+id/status_indicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/status_green"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Online"
            android:textColor="@color/cyber_green"
            android:textSize="16sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/device_id_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Device ID: Loading..."
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/server_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Server: Connecting..."
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/data_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 Data: 0 records"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/scan_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔍 Run Security Scan"
        android:background="@color/cyber_green"
        android:textColor="#000000"
        android:textSize="16sp"
        android:padding="15dp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/scan_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready to scan..."
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="15dp"
        android:background="#1A1A2E"
        android:minHeight="100dp"/>

</LinearLayout>